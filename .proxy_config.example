# Example Proxy Configuration for Mac Terminal
# Copy this file to ~/.proxy_config and customize for your environment
# Then add to your ~/.zshrc: source ~/.proxy_config

# ================================================
# PROXY CONFIGURATION
# ================================================
# Update these values with your actual proxy settings

# Basic proxy configuration (no authentication)
export PROXY_HOST="proxy.company.com"
export PROXY_PORT="8080"

# If authentication is required, uncomment and configure:
# export PROXY_USER="your-username"
# export PROXY_PASS="your-password"  # Consider using keychain instead

# ================================================
# ENVIRONMENT VARIABLES
# ================================================

# Build proxy URLs
if [ -n "$PROXY_USER" ] && [ -n "$PROXY_PASS" ]; then
    PROXY_URL="http://${PROXY_USER}:${PROXY_PASS}@${PROXY_HOST}:${PROXY_PORT}"
else
    PROXY_URL="http://${PROXY_HOST}:${PROXY_PORT}"
fi

# Set proxy environment variables
export HTTP_PROXY="$PROXY_URL"
export HTTPS_PROXY="$PROXY_URL"
export http_proxy="$PROXY_URL"
export https_proxy="$PROXY_URL"

# No proxy for local addresses
export NO_PROXY="localhost,127.0.0.1,.local,.internal,*.company.com"
export no_proxy="localhost,127.0.0.1,.local,.internal,*.company.com"

# ================================================
# GIT CONFIGURATION
# ================================================

# Uncomment to automatically configure git proxy
# git config --global http.proxy "$PROXY_URL"
# git config --global https.proxy "$PROXY_URL"

# ================================================
# SSL CERTIFICATE CONFIGURATION
# ================================================

# If you have SSL certificate issues, uncomment ONE of these options:

# Option 1: Specify custom CA bundle (recommended)
# export SSL_CERT_FILE="/path/to/ca-bundle.crt"
# export REQUESTS_CA_BUNDLE="/path/to/ca-bundle.crt"
# git config --global http.sslCAInfo "/path/to/ca-bundle.crt"

# Option 2: Disable SSL verification (NOT RECOMMENDED - security risk)
# export NODE_TLS_REJECT_UNAUTHORIZED=0
# git config --global http.sslVerify false

# ================================================
# OPTIONAL: NPM/NODE.JS CONFIGURATION
# ================================================

# Uncomment if you use npm/Node.js
# npm config set proxy "$PROXY_URL"
# npm config set https-proxy "$PROXY_URL"

# ================================================
# OPTIONAL: RUBY/BUNDLER CONFIGURATION
# ================================================

# Bundler will automatically use HTTP_PROXY and HTTPS_PROXY
# No additional configuration needed for Ruby/Bundler

# ================================================
# HELPFUL ALIASES
# ================================================

# Quick proxy management aliases
alias proxy-on='source ~/.proxy_config'
alias proxy-off='unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy && git config --global --unset http.proxy && git config --global --unset https.proxy'
alias proxy-status='env | grep -i proxy'
alias proxy-test='curl -I https://api.github.com'

# ================================================
# USAGE INSTRUCTIONS
# ================================================

# To use this configuration:
# 1. Copy this file to ~/.proxy_config
# 2. Edit the PROXY_HOST, PROXY_PORT, and authentication settings above
# 3. Add this line to your ~/.zshrc or ~/.bash_profile:
#    source ~/.proxy_config
# 4. Reload your shell: source ~/.zshrc
#
# To test: curl -I https://api.github.com
#
# See DEVELOPMENT_SETUP.md for more information
